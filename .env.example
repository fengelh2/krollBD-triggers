# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit secrets.
# For GitHub Actions, set the same keys in:
#   https://github.com/fengelh2/krollBD/settings/secrets/actions

# SerpAPI — website discovery + email aggregator search
# Free tier: ~5,000 searches/mo. Sign up at serpapi.com
SERPAPI_KEY=

# Firecrawl — SPA-aware page scraping
# Paid per call. Sign up at firecrawl.dev
FIRECRAWL_API_KEY=

# Hunter.io — verified named-RO email finder (cascade Layer 4)
# Free tier: 50 lookups/mo. Sign up at hunter.io
HUNTER_API_KEY=
HUNTER_EMAIL=

# DeepSeek — classifier LLM (cheap)
# Get from platform.deepseek.com
DEEPSEEK_API_KEY=

# Anthropic — fallback classifier LLM
# Get from console.anthropic.com
ANTHROPIC_API_KEY=

# GitHub PAT — used by `gh` CLI for issue creation
# Needs `repo` scope. Get from github.com/settings/tokens/new
GITHUB_TOKEN=
